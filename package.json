{
  "name": "sts2-dashboard",
  "version": "1.0.4",
  "description": "Slay the Spire 2 Run Dashboard",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "build": {
    "appId": "com.sts2stats.app",
    "productName": "STS2 Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "scripts/**/*",
      "card render assets/**/*",
      "STS2S.ico",
      "Slay_the_Spire_2_icon.webp",
      "ATTRIBUTIONS.md",
      "CHANGELOG.md",
      "README.md",
      "package.json"
    ],
    "asarUnpack": [
      "card render assets/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "STS2S.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
